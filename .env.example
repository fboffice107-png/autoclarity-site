# ============================================================
# AutoClarity PPI portal — environment variable reference.
# Placeholder names only. Real values live in Cloudflare Pages
# secrets (wrangler pages secret put NAME) or .dev.vars locally.
# NEVER commit real values. NEVER put live Stripe keys anywhere
# until the owner has explicitly approved production.
# ============================================================

# --- Mode switches (plain vars, safe to set in wrangler.toml) ---
PPI_ENV=preview                # preview | production
PPI_MODE=request               # waitlist | request | live
PAYMENTS_ENABLED=false         # false | true
STRIPE_ENV=test                # test | live
BOOKING_ENABLED=true           # false | true
UPLOADS_ENABLED=true           # false | true
PUBLIC_BASE_URL=http://127.0.0.1:8788
SUPPORT_EMAIL=support@getautoclarity.com

# --- Turnstile ---
TURNSTILE_SITE_KEY=1x00000000000000000000AA          # public; test key shown
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA  # SECRET; test key shown

# --- Stripe (test mode only until owner approves live) ---
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER_use_your_own   # SECRET
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER_use_your_own # SECRET

# --- Email (optional; without RESEND_API_KEY messages are recorded, not sent) ---
RESEND_API_KEY=re_PLACEHOLDER_use_your_own           # SECRET
EMAIL_FROM="AutoClarity <notify@getautoclarity.com>"
ADMIN_NOTIFY_EMAIL=support@getautoclarity.com

# --- Admin access ---
# Production requires Cloudflare Access; ADMIN_DEV_KEY works only when
# PPI_ENV != production.
ADMIN_DEV_KEY=generate-a-long-random-string-for-preview   # SECRET
CF_ACCESS_TEAM_DOMAIN=yourteam.cloudflareaccess.com
CF_ACCESS_AUD=access-application-aud-tag
